# Apps Script Web App /exec URL (Execute as: Me, Access: Anyone with the link)
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec

# Portal login (required — gates the whole app)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Optional: dedicated cookie signing secret (defaults to a hash of the credentials)
AUTH_SECRET=replace-with-a-long-random-string
